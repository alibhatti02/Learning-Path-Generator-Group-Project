# Course Forge backend config
# Copy this file to .env and fill in your own values:
#   cp .env.example .env
# NEVER commit .env — it is gitignored for a reason.

# ============================================================================
# REQUIRED: Azure OpenAI (learning path generation + quiz fallback)
# Get these from Azure AI Foundry: https://ai.azure.com
# NOTE: Use the Foundry endpoint + Foundry API key (the classic Azure portal
# "Deployments" blade is deprecated for newer models like GPT-5).
# ============================================================================
AZURE_OPENAI_API_KEY=your-foundry-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5
AZURE_OPENAI_API_VERSION=2024-10-01-preview

# ============================================================================
# REQUIRED: YouTube Data API v3 (live video resources in learning paths)
# Each teammate needs their OWN key in their OWN Google Cloud project —
# quota (10,000 units/day) is per project, so sharing one project means
# sharing one quota pool. Setup steps are in the README under
# "Getting your own YouTube API key".
# ============================================================================
YOUTUBE_API_KEY=your-youtube-api-key

# ============================================================================
# REQUIRED: Frontend CORS origins (which URLs may call the backend)
# The defaults below work for local dev — no changes needed.
# ============================================================================
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============================================================================
# DATABASE: connection string (SQLAlchemy URL)
# Leave UNSET for local dev — defaults to a SQLite file (backend/courseforge.db).
# For Azure SQL, set it to your mssql+pyodbc URL (needs ODBC Driver 18, which the
# Dockerfile installs). URL-encode any special characters in the password.
#   DATABASE_URL=mssql+pyodbc://<user>:<password>@<server>.database.windows.net:1433/<db>?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no
# ============================================================================
# DATABASE_URL=

# ============================================================================
# REQUIRED: JWT signing secret (login sessions)
# Generate your own — it does NOT need to match anyone else's:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Without a fixed value, everyone gets logged out on every server restart.
# ============================================================================
JWT_SECRET=paste-your-generated-secret-here

# ============================================================================
# OPTIONAL: Ollama (free local quiz generation)
# If Ollama isn't running, quizzes automatically fall back to Azure OpenAI.
# Only relevant if you've installed Ollama and pulled the model:
#   ollama pull qwen3.5:9b
# ============================================================================
OLLAMA_HOST=http://localhost:11434
QUIZ_MODEL=qwen3.5:9b

# ============================================================================
# OPTIONAL: Rate limiting (slowapi)
# Sensible defaults are baked in — override only to tune. Format is "N/period",
# e.g. "10/minute", "15/hour". Auth limits are per-IP; AI limits are per-user.
# ============================================================================
# RL_REGISTER=5/hour
# RL_LOGIN=10/minute
# RL_ROADMAP=15/hour
# RL_QUIZ_GEN=40/hour
# RL_QUIZ_SUBMIT=40/hour
# RL_RESUME=10/hour
# Counters are in-memory (per process). Point this at Redis once you run more
# than one backend instance so limits are shared across them:
# RATE_LIMIT_STORAGE_URI=redis://localhost:6379
